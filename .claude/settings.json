{
  "permissions": {
    "allow": [
      "Bash(docker compose up*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose run --rm dbt*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(curl http://localhost*)",
      "Bash(npm run*)",
      "Bash(npm install*)",
      "Bash(sqlfluff lint*)",
      "Bash(sqlfluff fix*)",
      "Bash(python ingestion/ingest.py)"
    ],
    "deny": [
      "Bash(docker compose down -v*)",
      "Edit(.env*)",
      "Edit(.git/**)",
      "Read(.env*)",
      "Read(secrets/**)"
    ]
  },
  "env": {
    "CLICKHOUSE_HOST": "localhost",
    "CLICKHOUSE_PORT": "8123",
    "DBT_PROFILES_DIR": "./transform"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== DVF Analytics ===' && echo 'Silver models:' $(ls transform/models/silver/*.sql 2>/dev/null | wc -l) && echo 'Gold models:' $(ls transform/models/gold/*.sql 2>/dev/null | wc -l) && echo 'Recent:' && git log --oneline -3 2>/dev/null",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/sqlfluff-check.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-sql.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
